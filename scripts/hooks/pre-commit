#!/bin/bash
# project-kb pre-commit hook — runs kb-lint.py on staged *.md files.
# Installed from scripts/hooks/pre-commit into .git/hooks/pre-commit by
# scripts/install-hooks.sh.
#
# Note: git hooks run in a stripped env on macOS — `python3` may resolve to
# /usr/bin/python3 (Apple's system Python, no PyYAML) even when your
# interactive shell's python3 is different. This script probes common
# Python install locations for one that has PyYAML.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
staged_md=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)

# no markdown changes → no lint work, but still verify index freshness below

find_py_with_yaml() {
    for py in python3 \
              "$HOME/opt/anaconda3/bin/python3" \
              /opt/anaconda3/bin/python3 \
              /opt/homebrew/bin/python3 \
              /opt/homebrew/bin/python3.13 \
              /opt/homebrew/bin/python3.12 \
              /opt/homebrew/bin/python3.11 \
              /usr/local/bin/python3 \
              /Library/Frameworks/Python.framework/Versions/3.13/bin/python3 \
              /Library/Frameworks/Python.framework/Versions/3.12/bin/python3 \
              /Library/Frameworks/Python.framework/Versions/3.11/bin/python3 \
              /Library/Frameworks/Python.framework/Versions/3.10/bin/python3; do
        if command -v "$py" >/dev/null 2>&1 && "$py" -c "import yaml" >/dev/null 2>&1; then
            echo "$py"
            return 0
        fi
    done
    return 1
}

py=$(find_py_with_yaml) || {
    cat >&2 <<EOF
kb-lint: no python3 with PyYAML found on this machine.
  Install for your default python3:   python3 -m pip install pyyaml
  For the anaconda base interpreter:  \$HOME/opt/anaconda3/bin/python3 -m pip install pyyaml
Hooks then work automatically.
EOF
    exit 2
}

if [ -n "$staged_md" ]; then
    abs_paths=$(echo "$staged_md" | sed "s|^|$repo_root/|")
    # shellcheck disable=SC2086
    "$py" "$repo_root/scripts/kb-lint.py" $abs_paths
fi

# Keep auto-generated INDEX.md files in sync, then stage any that changed.
#
# Why auto-stage (and not the old `--check`-and-reject)? INDEX.md files are
# derived *purely* from each entry's `description:` frontmatter — nobody
# hand-reviews them, the generator is their source of truth. Re-staging a
# regenerated index isn't a "silent write" of unreviewed intent (the footgun
# the rest of this hook guards against); it's keeping a derived artifact
# consistent with content already in the commit. The repo already required
# every commit to leave ALL indexes fresh — this enforces that invariant by
# fixing instead of rejecting.
#
# This matters because of the post-commit auto-push: with `--check`, a
# forgotten index meant commit → amend → and since origin was already pushed,
# a force-push. Auto-staging removes the #1 reason to amend. Scoped strictly
# to INDEX.md; source files are never touched.
"$py" "$repo_root/scripts/rebuild-indexes.py" >/dev/null

# Stage every INDEX.md the rebuild created or modified. porcelain's last
# field is the path; INDEX.md files are never renamed, so $NF is safe.
changed_indexes=$(cd "$repo_root" && git status --porcelain | awk '$NF ~ /INDEX\.md$/ {print $NF}')
if [ -n "$changed_indexes" ]; then
    # shellcheck disable=SC2086
    (cd "$repo_root" && git add $changed_indexes)
fi
